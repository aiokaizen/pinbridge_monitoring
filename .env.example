# Copy this file to `.env` before running the monitoring stack.
#
# This stack builds from a local OpenStatus checkout, not upstream `main`.
# Keep `monitoring/` and `openstatus/` on the server under the same parent
# directory, or override `OPENSTATUS_SOURCE_DIR` with an absolute path.

# ------------------------------------------------------------------------------
# Public domains and loopback binds
# ------------------------------------------------------------------------------
MONITORING_DASHBOARD_DOMAIN=openstatus.example.com
MONITORING_STATUS_DOMAIN=status.example.com
DASHBOARD_PUBLIC_URL=https://openstatus.example.com
STATUS_PAGE_PUBLIC_URL=https://status.example.com
MONITORING_DASHBOARD_BIND_IP=127.0.0.1
MONITORING_DASHBOARD_BIND_PORT=3002
MONITORING_STATUS_BIND_IP=127.0.0.1
MONITORING_STATUS_BIND_PORT=3003

# ------------------------------------------------------------------------------
# OpenStatus source / image tags
# ------------------------------------------------------------------------------
OPENSTATUS_SOURCE_DIR=../openstatus
OPENSTATUS_BUILD_TAG=selfhost-local

# ------------------------------------------------------------------------------
# Core application config
# ------------------------------------------------------------------------------
NODE_ENV=production
SELF_HOST=true
AUTH_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_TOKEN=replace-with-a-long-random-secret

# ------------------------------------------------------------------------------
# Self-host routing
# ------------------------------------------------------------------------------
CHECKER_BASE_URL=http://checker:8080
CHECKER_REGION=ams
WORKFLOWS_BASE_URL=http://workflows:3000
OPENSTATUS_WORKFLOWS_URL=http://workflows:3000
OPENSTATUS_INGEST_URL=http://server:3000

# ------------------------------------------------------------------------------
# Database / queue / analytics
# ------------------------------------------------------------------------------
DATABASE_URL=http://libsql:8080
SQLD_DB_PATH=/var/lib/sqld/iku.db
DATABASE_AUTH_TOKEN=
UPSTASH_REDIS_REST_URL=http://redis-http:80
UPSTASH_REDIS_REST_TOKEN=replace-with-a-long-random-secret
TINYBIRD_URL=http://tinybird-local:7181
TINY_BIRD_API_KEY=

# ------------------------------------------------------------------------------
# Email / auth providers
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_replace_me

# Optional OAuth providers. Omit them entirely if unused.
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ------------------------------------------------------------------------------
# Private location
# ------------------------------------------------------------------------------
# Create this in the OpenStatus dashboard after first boot.
OPENSTATUS_PRIVATE_LOCATION_KEY=replace-after-bootstrap

# ------------------------------------------------------------------------------
# Optional integrations
# ------------------------------------------------------------------------------
# Omit unused optional integrations from the real `.env`.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
# OPENPANEL_CLIENT_SECRET=
# SLACK_SUPPORT_WEBHOOK_URL=
# TELEGRAM_BOT_TOKEN=
# PAGERDUTY_APP_ID=
# PROJECT_ID_VERCEL=
# TEAM_ID_VERCEL=
# VERCEL_AUTH_BEARER_TOKEN=
# BLOB_READ_WRITE_TOKEN=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# UNKEY_API_ID=
# UNKEY_TOKEN=

# ------------------------------------------------------------------------------
# PinBridge monitor targets
# ------------------------------------------------------------------------------
PINBRIDGE_WEBAPP_URL=https://app.pinbridge.io/
PINBRIDGE_API_HEALTHZ_URL=https://api.pinbridge.io/healthz
PINBRIDGE_API_READYZ_URL=https://api.pinbridge.io/readyz
PINBRIDGE_API_STATUSZ_URL=https://api.pinbridge.io/statusz

# Optional if `/statusz` needs auth.
# PINBRIDGE_STATUSZ_AUTHORIZATION_HEADER=Bearer replace-with-admin-token
# PINBRIDGE_MONITORING_SOURCE_IP=203.0.113.10
