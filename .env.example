# Copy this file to `.env` before running the monitoring stack.
#
# The stack binds only these loopback ports on the host:
# - http://${MONITORING_DASHBOARD_BIND_IP}:${MONITORING_DASHBOARD_BIND_PORT} for the operator dashboard
# - http://${MONITORING_STATUS_BIND_IP}:${MONITORING_STATUS_BIND_PORT} for the public status page
#
# Everything else stays on the internal Docker network. Your system nginx should
# terminate TLS and proxy the two public domains to those loopback ports.

# ------------------------------------------------------------------------------
# Public domains and TLS
# ------------------------------------------------------------------------------
MONITORING_DASHBOARD_DOMAIN=openstatus.example.com
MONITORING_STATUS_DOMAIN=status.example.com
DASHBOARD_PUBLIC_URL=https://openstatus.example.com
STATUS_PAGE_PUBLIC_URL=https://status.example.com
MONITORING_DASHBOARD_BIND_IP=127.0.0.1
MONITORING_DASHBOARD_BIND_PORT=3002
MONITORING_STATUS_BIND_IP=127.0.0.1
MONITORING_STATUS_BIND_PORT=3003

# ------------------------------------------------------------------------------
# OpenStatus source / build
# ------------------------------------------------------------------------------
# Git ref or tag used when Docker builds the OpenStatus app services.
OPENSTATUS_GIT_REF=main

# ------------------------------------------------------------------------------
# Core application config
# ------------------------------------------------------------------------------
NODE_ENV=production
AUTH_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-with-a-long-random-secret
SUPER_ADMIN_TOKEN=replace-with-a-long-random-secret
SELF_HOST=true

# ------------------------------------------------------------------------------
# Email / auth providers
# ------------------------------------------------------------------------------
# Required for magic-link login when SELF_HOST=true.
RESEND_API_KEY=re_replace_me

# Optional OAuth providers.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ------------------------------------------------------------------------------
# Database / analytics
# ------------------------------------------------------------------------------
DATABASE_URL=http://libsql:8080
DATABASE_AUTH_TOKEN=
TINYBIRD_URL=http://tinybird-local:7181
TINY_BIRD_API_KEY=

# ------------------------------------------------------------------------------
# Private location
# ------------------------------------------------------------------------------
# Generate this in the OpenStatus dashboard after first boot:
# Settings -> Private Locations -> Create private location.
OPENSTATUS_PRIVATE_LOCATION_KEY=replace-after-bootstrap

# Internal ingest URL for the private-location container.
OPENSTATUS_INGEST_URL=http://server:3000

# ------------------------------------------------------------------------------
# Optional integrations
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_CLIENT_SECRET=
SLACK_SUPPORT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
PAGERDUTY_APP_ID=

# ------------------------------------------------------------------------------
# Optional Vercel / Blob / Stripe / Unkey support
# ------------------------------------------------------------------------------
PROJECT_ID_VERCEL=
TEAM_ID_VERCEL=
VERCEL_AUTH_BEARER_TOKEN=
BLOB_READ_WRITE_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
UNKEY_API_ID=
UNKEY_TOKEN=

# ------------------------------------------------------------------------------
# Optional GCP support
# ------------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_LOCATION=
GCP_CLIENT_EMAIL=
GCP_PRIVATE_KEY=

# ------------------------------------------------------------------------------
# PinBridge monitor targets
# ------------------------------------------------------------------------------
# These are not consumed directly by Docker Compose. They live here so the
# monitoring environment keeps the target URLs in one place when you configure
# the actual monitors inside OpenStatus.
PINBRIDGE_WEBAPP_URL=https://app.pinbridge.io/
PINBRIDGE_API_HEALTHZ_URL=https://api.pinbridge.io/healthz
PINBRIDGE_API_READYZ_URL=https://api.pinbridge.io/readyz
PINBRIDGE_API_STATUSZ_URL=https://api.pinbridge.io/statusz

# Optional if your internal /statusz endpoint requires a bearer token or fixed
# source IP allowlisting. OpenStatus lets you configure custom headers per
# monitor, so keep the token value here for operator reference only.
PINBRIDGE_STATUSZ_AUTHORIZATION_HEADER=
PINBRIDGE_MONITORING_SOURCE_IP=
